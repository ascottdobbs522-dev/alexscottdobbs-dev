---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const projects = [
  {
    type: 'iOS App · SwiftUI',
    name: 'KetoLog',
    desc: 'A native keto diet companion targeting iOS 26 with Liquid Glass design. Macro tracking via Open Food Facts API, intermittent fasting tracking, weight logging, and a custom suggestion engine.',
    tags: ['SwiftUI', 'SwiftData', 'HealthKit', 'Firebase'],
  },
  {
    type: 'Mixed Reality · Unity',
    name: 'KetoLog XR',
    desc: 'A Meta Quest 3 mixed reality companion to KetoLog. Reads live nutrition and fasting data from Firebase Firestore synced in real-time from the iOS app via HealthKit.',
    tags: ['Unity', 'Meta Quest 3', 'Firebase', 'MR Passthrough'],
  },
  {
    type: 'Apple Watch · Gesture Control',
    name: 'WristPointer',
    desc: 'Personal-use Apple Watch app that converts wrist gestures into mouse pointer input — inspired by discontinued gesture mouse tools. Full feasibility document and build roadmap produced.',
    tags: ['watchOS', 'CoreMotion', 'Swift'],
  },
  {
    type: 'Hardware · Fusion 360',
    name: 'Flush MicroSD Adapter',
    desc: 'Custom flush-fitting microSD card adapter for the 2023 MacBook Pro 14". Progressing from 3D-printed PLA prototypes to CNC-machined aluminium. Designed entirely in Fusion 360.',
    tags: ['Fusion 360', '3D Printing', 'CNC'],
  },
  {
    type: 'macOS / iOS App',
    name: 'FastTrack',
    desc: 'A clean fasting tracker originally built for macOS, ported to iOS. Managed via Claude Code with CLAUDE.md session continuity for sustained, context-aware development sessions.',
    tags: ['SwiftUI', 'macOS', 'iOS', 'Claude Code'],
  },
  {
    type: 'Portfolio · Astro',
    name: 'alexscottdobbs.dev',
    desc: 'This site. Built with Astro for zero-JS static delivery, card-based minimal layout, and a dark developer aesthetic. Ongoing iteration with Claude as a design and code collaborator.',
    tags: ['Astro', 'TypeScript', 'CSS'],
  },
];

const apps = [
  {
    name: 'KetoLog',
    desc: 'iOS keto companion — macro tracking, fasting, weight logging, Liquid Glass UI',
    status: 'In Development',
    cls: 'status-dev',
  },
  {
    name: 'KetoLog XR',
    desc: 'Meta Quest 3 mixed reality companion app synced to KetoLog via Firebase',
    status: 'In Development',
    cls: 'status-dev',
  },
  {
    name: 'FastTrack',
    desc: 'macOS and iOS fasting tracker with clean minimal interface',
    status: 'Alpha',
    cls: 'status-alpha',
  },
  {
    name: 'WristPointer',
    desc: 'Apple Watch gesture-to-mouse input app — feasibility complete, build pending',
    status: 'Planned',
    cls: 'status-planned',
  },
];

const devStack = ['Swift', 'SwiftUI', 'SwiftData', 'SceneKit', 'Xcode', 'Unity', 'Firebase'];
const designStack = ['Fusion 360', 'Figma', 'GitHub', 'Claude Code'];
const opsStack = ['Case Management', 'Data Coordination', 'Process Documentation', 'Claims Handling'];
---

<Layout>
  <div class="glow-blob"></div>

  <!-- NAV -->
  <nav id="nav">
    <a href="#home" class="nav-logo">ASD<span>.</span></a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#apps">Apps</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section id="home">
    <div class="hero-inner">
      <div class="hero-label">alexscottdobbs.dev</div>
      <h1>Operations.<br /><em>Code.</em><br />Craft.</h1>
      <p class="hero-sub">
        Civil service operations professional turned independent iOS developer.
        I build tools that solve real problems — from workflow automation to native Apple apps.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">View Projects ↓</a>
        <a href="#contact" class="btn btn-ghost">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="section-wrap">
      <div class="section-header fade-in">
        <span class="section-num">01 —</span>
        <h2>About</h2>
        <div class="section-line"></div>
      </div>
      <div class="about-grid">
        <div class="about-text fade-in">
          <p>
            Based in <strong>Belfast, Northern Ireland</strong>. Five years in the Northern Ireland Civil Service
            at the Department for Communities — case management, data coordination, and documentation at scale.
          </p>
          <p>
            Outside of that: building <strong>native iOS and macOS apps</strong> with Swift and SwiftUI,
            prototyping hardware in Fusion 360, and experimenting with mixed reality on Meta Quest 3.
          </p>
          <p>
            I'm drawn to work that sits at the intersection of <strong>structured process and hands-on building</strong> —
            whether that's a case management workflow or a polished SwiftUI interface.
          </p>
          <div style="margin-top: 2rem;">
            <a href="#contact" class="btn btn-ghost">Open to remote roles →</a>
          </div>
        </div>
        <div class="about-stack fade-in">
          <div>
            <div class="stack-group-label">Development</div>
            <div class="tag-row">
              {devStack.map((s) => <span class="tag">{s}</span>)}
            </div>
          </div>
          <div>
            <div class="stack-group-label">Design &amp; Tools</div>
            <div class="tag-row">
              {designStack.map((s) => <span class="tag">{s}</span>)}
            </div>
          </div>
          <div>
            <div class="stack-group-label">Operations</div>
            <div class="tag-row">
              {opsStack.map((s) => <span class="tag">{s}</span>)}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects">
    <div class="section-wrap">
      <div class="section-header fade-in">
        <span class="section-num">02 —</span>
        <h2>Projects</h2>
        <div class="section-line"></div>
      </div>
      <div class="project-grid">
        {projects.map((p) => (
          <div class="project-card fade-in">
            <div class="project-type">{p.type}</div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <div class="project-tags">
              {p.tags.map((t) => <span class="project-tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- APPS -->
  <section id="apps">
    <div class="section-wrap">
      <div class="section-header fade-in">
        <span class="section-num">03 —</span>
        <h2>App Status</h2>
        <div class="section-line"></div>
      </div>
      <div class="apps-list">
        {apps.map((a) => (
          <div class="app-row fade-in">
            <div class="app-name">{a.name}</div>
            <div class="app-desc">{a.desc}</div>
            <div class={`app-status ${a.cls}`}>{a.status}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="section-wrap">
      <div class="section-header fade-in">
        <span class="section-num">04 —</span>
        <h2>Contact</h2>
        <div class="section-line"></div>
      </div>
      <div class="contact-inner">
        <div class="contact-text fade-in">
          <p>
            Open to remote roles in case management, claims handling, data coordination,
            or iOS development collaborations. Based in Belfast — working anywhere.
          </p>
          <div class="contact-links">
            <a href="mailto:alex@alexscottdobbs.dev" class="contact-link">
              <div class="contact-link-icon">@</div>
              alex@alexscottdobbs.dev
            </a>
            <a href="https://github.com/alexscottdobbs" class="contact-link" target="_blank" rel="noopener noreferrer">
              <div class="contact-link-icon">GH</div>
              github.com/alexscottdobbs
            </a>
            <a href="https://linkedin.com/in/alexscottdobbs" class="contact-link" target="_blank" rel="noopener noreferrer">
              <div class="contact-link-icon">in</div>
              linkedin.com/in/alexscottdobbs
            </a>
          </div>
        </div>
        <form class="contact-form fade-in" action="https://formspree.io/f/yourformid" method="POST">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Send Message →</button>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-left">© 2026 Alex Scott Dobbs<span>.</span> Belfast, NI.</div>
    <div class="footer-right">Operations · iOS · Hardware</div>
  </footer>
</Layout>

<script>
  // Mark JS as available so fade-in elements start hidden (CSS handles no-JS fallback).
  document.documentElement.classList.remove('no-js');

  // Shrinking nav on scroll
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener(
      'scroll',
      () => nav.classList.toggle('scrolled', window.scrollY > 40),
      { passive: true }
    );
  }

  // Fade in on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

  // Glow blob follows cursor
  const blob = document.querySelector<HTMLElement>('.glow-blob');
  if (blob) {
    document.addEventListener(
      'mousemove',
      (e) => {
        blob.style.left = e.clientX - 300 + 'px';
        blob.style.top = e.clientY - 300 + 'px';
      },
      { passive: true }
    );
  }
</script>
